{
  "name": "booknest",
  "version": "1.0.0",
  "description": "Book Nest - Adaptive Reading Platform",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamAmer/BookNest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/iamAmer/BookNest/issues"
  },
  "homepage": "https://github.com/iamAmer/BookNest#readme",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
